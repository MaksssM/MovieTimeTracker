<?xml version="1.0" encoding="utf-8"?>
<!-- Premium background matching Cinephile Dark Theme -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Solid Base Dark Background -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/background" />
        </shape>
    </item>

    <!-- Subtle Cyan ambient glow - top left -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="400dp"
                android:centerX="0.04"
                android:centerY="0.06"
                android:startColor="#1A00E0FF"
                android:endColor="#00000000" />
        </shape>
    </item>

    <!-- Subtle Purple glow - bottom right -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="radial"
                android:gradientRadius="500dp"
                android:centerX="0.95"
                android:centerY="0.88"
                android:startColor="#1A6E06D0"
                android:endColor="#00000000" />
        </shape>
    </item>

</layer-list>
